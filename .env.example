# Dexter backend
DEXTER_BACKEND_URL=http://127.0.0.1:8000
DEXTER_FAST_TOOL_RESPONSES=1
DEXTER_MEMORY_ENABLED=true

# LLM provider
DEXTER_LLM_PROVIDER=openrouter
DEXTER_OPENROUTER_API_KEY=
DEXTER_OPENROUTER_MODEL=openai/gpt-4o-mini
DEXTER_OPENROUTER_RESPONSE_FORMAT=json_object

# Browser automation
DEXTER_BROWSER_CONNECTION=cdp
DEXTER_BROWSER_CDP_URL=http://127.0.0.1:9222
DEXTER_BROWSER_AUTO_LAUNCH_CDP=false
DEXTER_BROWSER_CDP_RELAUNCH_EXISTING=false
DEXTER_BROWSER_CDP_FORCE_QUIT_EXISTING=false
DEXTER_BROWSER_CDP_FALLBACK_PERSISTENT=false
DEXTER_BROWSER_PROFILE_DIR=

# Dexter Jobs OS
DEXTER_JOBS_CONFIG=config/jobs.yaml
DEXTER_JOBS_DB_URL=sqlite:///data/jobs/jobs.sqlite3
DEXTER_JOBS_DEMO_MODE=false
DEXTER_JOBS_OS_LEGACY_LINKS=false

# Job source API credentials
USAJOBS_API_KEY=
USAJOBS_EMAIL=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
GITHUB_TOKEN=
